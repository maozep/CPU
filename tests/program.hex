1448  // PC=0: R2 = R1 + R1 (0 + 0 = 0)  -> ADD: Check zero + zero
164F  // PC=1: R3 = R1 + R7 (0 + 1 = 1)  -> ADD: Check increment
24DF  // PC=2: R2 = R3 - R7 (1 - 1 = 0)  -> SUB: Check zero flag & subtraction
38DF  // PC=3: R4 = R3 & R7 (1 & 1 = 1)  -> AND: Check logical bitwise AND
4A4F  // PC=5: R5 = R2 | R7 (0 | 1 = 1)  -> OR:  Check logical bitwise OR
0000  // PC=6: HALT